{
  "name": "hm-delbestilling",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.6.2"
  },
  "scripts": {
    "dev": "pnpm run --prefix client dev",
    "playwright": "pnpm run --prefix client playwright",
    "playwright:ui": "pnpm run --prefix client playwright:ui",
    "build": "concurrently --kill-others-on-fail \"pnpm run --prefix client build\" \"go build -C server ./...\""
  }
}