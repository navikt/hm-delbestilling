{
  "name": "hm-delbestilling",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "devDependencies": {
    "prettier": "^2.6.2"
  },
  "scripts": {
    "install": "cd client && pnpm install",
    "dev": "pnpm run --prefix client dev",
    "playwright": "pnpm run --prefix client playwright",
    "playwright:ui": "pnpm run --prefix client playwright:ui",
    "build:client": "pnpm run --prefix client build",
    "build:server": "go build -C server ./...",
    "build": "pnpm run build:client && pnpm run build:server"
  }
}